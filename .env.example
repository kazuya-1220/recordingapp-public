# ============================================================
#  RecordingApp (public demo) 環境変数テンプレート
#  このファイルを .env にコピーして値を設定してください。
#  .env は .gitignore 済みでコミットされません。実キーは絶対にコミットしないこと。
#  値の取得方法は SETUP.md を参照。
# ============================================================

# --- サーバ側（server.ts が使用） ---
# Google AI Studio (https://aistudio.google.com/apikey) で取得した Gemini API キー
GEMINI_API_KEY=AQ.Ab8RN6IAkX2i6jO_zcDfa0kSFpb6Zltm_zaKot-5Twn1bc9fMw

# --- クライアント側（Firebase Web SDK 設定 / VITE_ プレフィックス必須） ---
# Firebase コンソール → プロジェクト設定 → 「マイアプリ(Web)」の firebaseConfig の値
VITE_FIREBASE_API_KEY=AIzaSyCSxfhYSHsS6wcgRiBieE85L7IEtE35w7c
VITE_FIREBASE_AUTH_DOMAIN=it-kadai.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=it-kadai
VITE_FIREBASE_STORAGE_BUCKET=it-kadai.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=776537061301
VITE_FIREBASE_APP_ID=1:776537061301:web:3537f1cb06afb68ed94bfc

# Firestore のデータベースID（通常は既定の (default) のまま）
VITE_FIREBASE_FIRESTORE_DB_ID=(default)

# --- 任意：サインイン可能なメールドメインの制限 ---
# 空欄なら全 Google アカウントを許可（外部公開デモの既定）。
# 例: tax-brain.page と設定すると、そのドメインのアカウントのみサインイン可。
VITE_ALLOWED_EMAIL_DOMAIN=
