rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    // 課題（デモ）用：Googleログインを行わず匿名認証で利用するため、サインイン済み
    // （匿名を含む）であれば許可する。所有者スコープは uid で担保する。
    function isTaxBrainUser() {
      return isSignedIn();
    }

    function isOwner(userId) {
      return isTaxBrainUser() && request.auth.uid == userId;
    }

    function isValidRecording(data) {
      return data.keys().hasAll(['title', 'text', 'createdAt', 'kintoneSynced', 'userId']) &&
             data.title is string && data.title.size() <= 200 &&
             data.text is string && data.text.size() <= 100000 &&
             data.createdAt is number &&
             data.kintoneSynced is bool &&
             data.userId == request.auth.uid;
    }

    function isValidLiveSession(data) {
      return data.keys().hasAll(['text', 'updatedAt', 'sessionId']) &&
             data.text is string && data.text.size() <= 100000 &&
             data.updatedAt is number &&
             data.sessionId is string;
    }

    // Recordings: Only the owner (and only @tax-brain.page accounts) can manage their data
    match /recordings/{recordingId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isTaxBrainUser() && isValidRecording(request.resource.data);
      allow update: if isOwner(resource.data.userId) && isValidRecording(request.resource.data);
    }

    // User settings: each user can read/write their own settings doc (keyed by email)
    match /userSettings/{email} {
      allow read, write: if isTaxBrainUser() && request.auth.token.email == email;
    }

    // Beta Reviews: Any @tax-brain.page user can create and read; only admin can update
    match /betaReviews/{reviewId} {
      allow read: if isTaxBrainUser();
      allow create: if isTaxBrainUser();
      allow update: if isTaxBrainUser();
      allow delete: if false;
    }

    // Live Sessions: Accessible by the 4-digit ID (domain-restricted write)
    // create: full structure required (Recorder initialises the doc)
    // update: only auth check — LiveView sends partial fields (customerName etc.)
    //         so we cannot run isValidLiveSession on the merged result here
    match /liveSessions/{sessionId} {
      allow get: if true;
      allow create: if isTaxBrainUser() && isValidLiveSession(request.resource.data);
      allow update: if isTaxBrainUser();
      allow delete: if false;
      allow list: if false;
    }
  }
}
